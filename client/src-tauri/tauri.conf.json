{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MONOLITH",
  "version": "0.1.0",
  "identifier": "com.parvane.monolith",
  "build": {
    "frontendDist": "../dist",
    "beforeBuildCommand": "node stage-frontend.mjs",
    "beforeDevCommand": "node stage-frontend.mjs"
  },
  "app": {
    "windows": [
      {
        "title": "MONOLITH — operator console",
        "width": 1600,
        "height": 1000,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
